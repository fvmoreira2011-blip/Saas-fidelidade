rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.email.lower() == "fvmoreira2011@gmail.com" ||
         request.auth.token.email.lower() == "superadmin@fidelidadevarejo.com" ||
         request.auth.token.email.lower() == "fidelidade@sliceshare.com.br" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin')));
    }

    function isApproved() {
      return isSignedIn() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true));
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.approved is bool &&
             data.role in ['admin', 'user', 'superadmin'] &&
             (data.createdAt is string || !('createdAt' in data));
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 200 &&
             (data.points is number || !('points' in data)) &&
             (data.companyId is string || !('companyId' in data)) &&
             (data.lastPurchaseDate is string || !('lastPurchaseDate' in data)) &&
             (data.createdAt is string || !('createdAt' in data)) &&
             (data.updatedAt is string || !('updatedAt' in data)) &&
             (data.isDeleted is bool || !('isDeleted' in data)) &&
             (data.deletedAt is string || !('deletedAt' in data)) &&
             (data.photoURL is string || !('photoURL' in data)) &&
             (data.authUid is string || !('authUid' in data)) &&
             (data.birthDate is string || !('birthDate' in data)) &&
             (data.email is string || !('email' in data)) &&
             (data.totalSpent is number || !('totalSpent' in data)) &&
             (data.purchasesCount is number || !('purchasesCount' in data)) &&
             (data.totalPurchases is number || !('totalPurchases' in data)) &&
             (data.cashbackBalance is number || !('cashbackBalance' in data));
    }

    function isValidPurchase(data) {
      return data.customerId is string &&
             data.customerName is string &&
             data.amount is number &&
             data.date is string &&
             (data.pointsEarned is number || !('pointsEarned' in data)) &&
             (data.companyId is string || !('companyId' in data)) &&
             (data.items is list || !('items' in data)) &&
             (data.campaignId is string || data.campaignId == null || !('campaignId' in data)) &&
             (data.bonusPoints is number || !('bonusPoints' in data)) &&
             (data.cashbackEarned is number || !('cashbackEarned' in data)) &&
             (data.originalPoints is number || !('originalPoints' in data));
    }

    function isValidRedemption(data) {
      return data.customerId is string &&
             data.prize is string &&
             data.pointsValue is number &&
             (data.cost is number || !('cost' in data)) &&
             data.date is string &&
             (data.companyId is string || !('companyId' in data)) &&
             (data.voucherCode is string || !('voucherCode' in data)) &&
             (data.status is string || !('status' in data));
    }

    function isValidGoal(data) {
      return data.month is string &&
             data.value is number &&
             (data.workingDays is number || !('workingDays' in data)) &&
             (data.companyId is string || !('companyId' in data));
    }

    // 1. Connection Test
    match /test/connection {
      allow read: if isSignedIn();
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // 3. Customers Collection
    match /customers/{customerId} {
      allow read: if true;
      allow create: if isApproved() && incoming().companyId == request.auth.uid && isValidCustomer(incoming());
      allow update: if (isApproved() && existing().companyId == request.auth.uid && isValidCustomer(incoming())) || 
                     (isSignedIn() && existing().authUid == request.auth.uid && isValidCustomer(incoming())) ||
                     isAdmin();
      allow delete: if isAdmin();
    }

    // 4. Purchases Collection
    match /purchases/{purchaseId} {
      allow read: if isApproved() || (isSignedIn() && existing().customerId == request.auth.uid) || isAdmin();
      allow create: if isApproved() && incoming().companyId == request.auth.uid && isValidPurchase(incoming());
      allow update: if (isApproved() && existing().companyId == request.auth.uid && isValidPurchase(incoming())) || isAdmin();
      allow delete: if isAdmin();
    }

    // 5. Redemptions Collection
    match /redemptions/{redemptionId} {
      allow read: if isApproved() || (isSignedIn() && resource.data.customerId == request.auth.uid) || isAdmin();
      allow create: if isApproved() && incoming().companyId == request.auth.uid && isValidRedemption(incoming());
      allow update: if (isApproved() && existing().companyId == request.auth.uid && isValidRedemption(incoming())) || isAdmin();
      allow delete: if isAdmin();
    }

    // 6. Configs Collections
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && configId == request.auth.uid);
    }

    match /configs/{configId} {
      allow read: if true;
      allow create, update: if isAdmin() || (isSignedIn() && configId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 7. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isApproved() && incoming().companyId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().customerId == request.auth.uid);
    }

    // 8. Goals Collection
    match /goals/{goalId} {
      allow read: if isApproved() || isAdmin();
      allow create: if isApproved() && incoming().companyId == request.auth.uid && isValidGoal(incoming());
      allow update: if (isApproved() && existing().companyId == request.auth.uid && isValidGoal(incoming())) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
