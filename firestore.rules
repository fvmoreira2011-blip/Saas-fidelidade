rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.email.lower() == "fvmoreira2011@gmail.com" ||
         request.auth.token.email.lower() == "superadmin@fidelidadevarejo.com" ||
         request.auth.token.email.lower() == "fidelidade@sliceshare.com.br" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin')));
    }

    function isApproved() {
      return isSignedIn() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true));
    }

    // Validation Blueprints
    function isValidCustomer(data) {
      return data.name is string && data.name.size() <= 200 &&
             (data.companyId is string || !('companyId' in data));
    }

    function isValidPurchase(data) {
      return (data.customerId is string || !('customerId' in data)) &&
             (data.amount is number || !('amount' in data)) &&
             (data.companyId is string || !('companyId' in data));
    }

    function isValidRedemption(data) {
      return (data.customerId is string || !('customerId' in data)) &&
             (data.companyId is string || !('companyId' in data));
    }

    function isValidGoal(data) {
      return (data.value is number || !('value' in data)) &&
             (data.companyId is string || !('companyId' in data));
    }

    function isValidHistory(data) {
      return data.companyId is string &&
             data.campaignName is string;
    }

    // 1. Connection Test
    match /test/connection {
      allow read: if isSignedIn();
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // 3. Customers Collection
    match /customers/{customerId} {
      allow read: if true;
      allow create: if isApproved() && (incoming().companyId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isApproved() && existing().companyId == request.auth.uid) || (isSignedIn() && existing().authUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 4. Purchases Collection
    match /purchases/{purchaseId} {
      allow read: if isAdmin() || isApproved() || (isSignedIn() && existing().customerId == request.auth.uid);
      allow create: if isApproved() && (incoming().companyId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isApproved() && existing().companyId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 5. Redemptions Collection
    match /redemptions/{redemptionId} {
      allow read: if isAdmin() || isApproved() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isApproved() && (incoming().companyId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isApproved() && existing().companyId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 6. Configs Collections
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && configId == request.auth.uid);
    }

    match /configs/{configId} {
      allow read: if true;
      allow create, update: if isAdmin() || (isSignedIn() && configId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 7. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isApproved() && (incoming().companyId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin() || (isSignedIn() && existing().customerId == request.auth.uid);
    }

    // 8. Goals Collection
    match /goals/{goalId} {
      allow read: if isAdmin() || isApproved();
      allow create: if isApproved() && (incoming().companyId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isApproved() && existing().companyId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 9. Promotion History
    match /promotion_history/{historyId} {
      allow read: if isApproved() || isAdmin();
      allow create: if isApproved() && (incoming().companyId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}

